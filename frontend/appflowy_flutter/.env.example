# Copy to .env and fill in before building (local development only).
# .env is gitignored — never commit it.
#
# In Docker deployments these values are passed as runtime environment variables
# to the container — no .env file is needed.

# AppFlowy Cloud server URL (baked in at compile time for local dev builds)
APPFLOWY_CLOUD_URL=https://your-appflowy-cloud-domain.example.com

# Optional
SENTRY_DSN=
INTERNAL_BUILD=
