# Backend and Authentik configuration for Flutter app dev builds
# REQUIRED: Set these environment variables before running the app
# Values come from the AppFlowy deployment, obtained via:
#   ssh rafa@bigboy "cd /home/rafa/env/osmosis/appflowy && cat .env | grep AUTHENTIK"
# Do not commit actual values to git.

# Launch command example:
#   APPFLOWY_CLOUD_URL=https://notes.osmosis.page \
#   AUTHENTIK_APP_SLUG=<value from bigboy .env> \
#   AUTHENTIK_CLIENT_ID=<value from bigboy .env> \
#   flutter run -d linux

APPFLOWY_CLOUD_URL=https://notes.osmosis.page
AUTHENTIK_BASE_URL=https://auth.osmosis.page