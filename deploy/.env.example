# Copy to .env and fill in SECRETS only — public values live in docker-compose.yml.
# .env is gitignored and must never be committed.
#
# Prerequisites:
#   Install the Loki Docker driver once per host:
#     docker plugin install grafana/loki-docker-driver:latest --alias loki --grant-all-permissions

# ─── Loki ─────────────────────────────────────────────────────────────────────
# Override the Loki host if your Grafana stack is on a different machine.
LOKI_HOST=192.168.1.66

# ─── AppFlowy Cloud version ───────────────────────────────────────────────────
APPFLOWY_CLOUD_VERSION=latest

# ─── SECRETS ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
APPFLOWY_JWT_SECRET=

# Admin account password for the AppFlowy Cloud API
APPFLOWY_ADMIN_PASSWORD=

# PostgreSQL password
POSTGRES_PASSWORD=

# MinIO root password
MINIO_ROOT_PASSWORD=

# ─── Optional overrides (defaults are fine for most deployments) ──────────────
POSTGRES_DB=appflowy
POSTGRES_USER=appflowy
MINIO_ROOT_USER=appflowy

# ─── Email / SMTP (optional — needed for workspace invitations) ───────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
